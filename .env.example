# LangSmith — copy this file to .env and fill in your values
# Get your API key from: https://smith.langchain.com/settings

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your_api_key_here
LANGCHAIN_PROJECT=langgraph-poc
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Azure Data Factory
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_RESOURCE_GROUP=my-resource-group
AZURE_DATA_FACTORY_NAME=my-adf-name

# ADF pipeline run ID to analyse (used by mcp_client.py and adf_agents.py CLI)
ADF_RUN_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# LLM — pick ONE block below

# Option A: Azure OpenAI (key doesn't start with sk-)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
OPENAI_MODEL=gpt-4o           # deployment name in your Azure resource
OPENAI_API_VERSION=2024-08-01-preview

# Option B: Standard OpenAI (key starts with sk-)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
